# Copy to .env and load manually, or set in the shell before starting the server.
# PowerShell:  $env:GEMINI_API_KEY="your_key"

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# 0.25–0.5 = more factual; higher = more varied wording
GEMINI_TEMPERATURE=0.35
GEMINI_MAX_OUTPUT_TOKENS=768
# 1 = JSON advice (advice_en, advice_darija, risk, focus_object); 0 = prose only
GEMINI_STRUCTURED_OUTPUT=1
# Optional: override the system instruction (long string)
# GEMINI_SYSTEM_INSTRUCTION=
# Horizontal camera FOV in degrees (phone main cam ~60–70). Wrong FOV = wrong distance.
CAMERA_HORIZONTAL_FOV_DEG=64
# If distances are always too high, try 0.75–0.9; too low, try 1.1–1.3
DEPTH_GLOBAL_SCALE=1.0
# ENABLE_GEMINI=0  -> skip Gemini (YOLO+depth+scene only)
# ENABLE_SCENE_MODEL=0  -> skip ResNet scene head
# Optional: paste your thesis "rule" text (e.g. distance policy) for Gemini
# GEMINI_EXTRA_RULES=
