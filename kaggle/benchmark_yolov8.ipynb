   "source": [
    "# ═══ STEP 0: Dependencies ═══\n",
    "!pip install -q ultralytics sahi fiftyone"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"trusted": true},
   "outputs": [],
   "source": [
    "# ═══ STEP 1: VisionAid Dataset Master Fixer (22 Classes) ═══\n",
    "import os, shutil, yaml, numpy as np\n",
    "from pathlib import Path\n",
    "from collections import Counter\n",
    "import fiftyone.zoo as foz\n",
    "\n",
    "ORIGINAL_DATA_YAML = \"/kaggle/input/datasets/salimarachrache/final-data/dataset/data.yaml\"\n",
    "WORKING_DIR = Path(\"/kaggle/working/visionaid_dataset_v22\")\n",
    "CLASS_NAMES = ['bench', 'bicycle', 'bus', 'bus_stop', 'car', 'crutch', 'curb', 'dog', 'fire_hydrant', 'motorcycle', 'person', 'pole', 'spherical_roadblock', 'stairs', 'stop_sign', 'street_light', 'traffic_light', 'train', 'tree', 'truck', 'warning_column', 'waste_container']\n",
    "\n",
    "def setup_and_fix():\n",
    "    if WORKING_DIR.exists(): \n",
    "        print(\"Dataset already exists, skipping copy.\")\n",
    "    else:\n",
    "        print(\"Copying original dataset...\")\n",
    "        shutil.copytree(Path(ORIGINAL_DATA_YAML).parent, WORKING_DIR)\n",
    "        \n",
    "    # ── COCO Injection ──\n",
    "    train_img_dir = WORKING_DIR / 'train' / 'images'\n",
    "    if not list(train_img_dir.glob(\"coco_*\")):\n",
    "        print(\"Injecting COCO samples...\")\n",
    "        dataset = foz.load_zoo_dataset(\"coco-2017\", splits=[\"train\"], classes=[\"person\", \"traffic light\"], max_samples=800)\n",
    "        COCO_MAP = {\"person\": 10, \"traffic light\": 16}\n",
    "        for sample in dataset:\n",
    "            dst_p = train_img_dir / (\"coco_\" + Path(sample.filepath).name)\n",
    "            shutil.copy(sample.filepath, dst_p)\n",
    "            lbl_p = WORKING_DIR / 'train' / 'labels' / (dst_p.stem + \".txt\")\n",
    "            with open(lbl_p, \"w\") as f:\n",
    "                if sample.ground_truth:\n",
    "                    for det in sample.ground_truth.detections:\n",
    "                        if det.label in COCO_MAP:\n",
    "                            x, y, w, h = det.bounding_box\n",
    "                            f.write(f\"{COCO_MAP[det.label]} {x+w/2} {y+h/2} {w} {h}\\n\")\n",
    "\n",
    "    # ── Write YAML ──\n",
    "    with open('/kaggle/working/data_v22.yaml', 'w') as f:\n",
    "        yaml.dump({'path': str(WORKING_DIR), 'train': 'train/images', 'val': 'valid/images', 'test': 'test/images', 'nc': 22, 'names': CLASS_NAMES}, f)\n",
    "\n",
    "setup_and_fix()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"trusted": true},
   "outputs": [],
   "source": [
    "# ═══ STEP 2: Training Benchmark Loop ═══\n",
    "from ultralytics import YOLO\n",
    "import pandas as pd\n",
    "\n",
    "MODELS = ['yolov8n.pt', 'yolov8s.pt']\n",
    "results = []\n",
    "\n",
    "for m_name in MODELS:\n",
    "    model = YOLO(m_name)\n",
    "    model.train(data='/kaggle/working/data_v22.yaml', epochs=50, imgsz=832, batch=16, device=0, name=f'bench_{m_name.replace(\".pt\",\"\")}')\n",
    "    \n",
    "    # Validation Standard\n",
    "    metrics = model.val(split='test', imgsz=832)\n",
    "    results.append({\n",
    "        'Model': m_name,\n",
    "        'mAP50': metrics.box.map50,\n",
    "        'mAP50-95': metrics.box.map,\n",
    "        'Precision': metrics.box.mp,\n",
    "        'Recall': metrics.box.mr\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(results)\n",
    "display(df)"
   ]
  }\n",
 ]
}
